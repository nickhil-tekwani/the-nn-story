# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — NEVER commit real secrets.
# In Vercel, add each of these under Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (from the Vercel Neon integration or neon.tech)
# Looks like: postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Auth.js (NextAuth v5) -------------------------------------------------------
# Generate a secret with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URI for local dev:  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI for prod:       https://YOUR-DOMAIN.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of Google emails that get admin access to /admin
ADMIN_EMAILS=nickhilct@gmail.com

# ---------------------------------------------------------------------------
# Public (exposed to the browser — must be prefixed NEXT_PUBLIC_)
# ---------------------------------------------------------------------------

# URL of the looping background video. Defaults to the bundled placeholder in
# /public. Swap to a Vercel Blob URL once you upload the real video.
NEXT_PUBLIC_VIDEO_URL=/placeholder-loop.mp4

# Event details (safe to expose)
NEXT_PUBLIC_EVENT_DATE=2026-09-19
NEXT_PUBLIC_EVENT_CITY=Cincinnati, OH
